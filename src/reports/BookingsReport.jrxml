<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="BookingsReport" pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <field name="bookingId" class="java.lang.Integer"/>
    <field name="customerName" class="java.lang.String"/>
    <field name="roomNumber" class="java.lang.String"/>
    <field name="checkIn" class="java.lang.String"/>
    <field name="checkOut" class="java.lang.String"/>
    <field name="totalAmount" class="java.math.BigDecimal"/>
    <field name="status" class="java.lang.String"/>

    <variable name="totalRevenue" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{totalAmount}]]></variableExpression>
    </variable>
    <variable name="bookingCount" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{bookingId}]]></variableExpression>
    </variable>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="802" height="30"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Hotel Management System - Bookings Report]]></text>
            </staticText>
            <textField pattern="dd-MMM-yyyy HH:mm">
                <reportElement x="0" y="32" width="802" height="20"/>
                <textElement textAlignment="Center">
                    <font size="10" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated: " + new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <staticText>
                <reportElement x="0" y="0" width="60" height="24" backcolor="#DDDDDD" mode="Opaque"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="60" y="0" width="180" height="24" backcolor="#DDDDDD" mode="Opaque"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Customer]]></text>
            </staticText>
            <staticText>
                <reportElement x="240" y="0" width="80" height="24" backcolor="#DDDDDD" mode="Opaque"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Room]]></text>
            </staticText>
            <staticText>
                <reportElement x="320" y="0" width="120" height="24" backcolor="#DDDDDD" mode="Opaque"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Check-in]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="0" width="120" height="24" backcolor="#DDDDDD" mode="Opaque"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Check-out]]></text>
            </staticText>
            <staticText>
                <reportElement x="560" y="0" width="120" height="24" backcolor="#DDDDDD" mode="Opaque"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Total (Rs.)]]></text>
            </staticText>
            <staticText>
                <reportElement x="680" y="0" width="122" height="24" backcolor="#DDDDDD" mode="Opaque"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="60" height="20"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{bookingId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="60" y="0" width="180" height="20"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{customerName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="240" y="0" width="80" height="20"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{roomNumber}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="320" y="0" width="120" height="20"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{checkIn}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="440" y="0" width="120" height="20"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{checkOut}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="560" y="0" width="120" height="20"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{totalAmount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="680" y="0" width="122" height="20"/>
                <box><pen lineWidth="0.25"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="40">
            <staticText>
                <reportElement x="440" y="10" width="120" height="20"/>
                <textElement textAlignment="Right"><font isBold="true"/></textElement>
                <text><![CDATA[Total Revenue:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="560" y="10" width="120" height="20"/>
                <textElement textAlignment="Right"><font isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{totalRevenue}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="60" y="10" width="180" height="20"/>
                <textElement textAlignment="Left"><font isItalic="true"/></textElement>
                <textFieldExpression><![CDATA["Total bookings: " + $V{bookingCount}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
